# ==========================================================================
# PANEL-CONTROL — variables de entorno (copiar como ".env" y completar).
# El .env está en .gitignore — NUNCA subir credenciales reales al repo.
# ==========================================================================

# --- Base de datos ---
# Local (dev): si lo dejás vacío usa un SQLite compartido en la raíz del proyecto.
# Producción (Render): pegá la "Internal Database URL" del Postgres de Render.
DATABASE_URL=

# --- Seguridad ---
# OBLIGATORIA y de >=32 caracteres: sin ella el panel NO arranca en producción.
# Generar con:  python -c "import secrets;print(secrets.token_urlsafe(48))"
# El panel usa preferentemente ADMIN_SECRET_KEY, que DEBE ser distinta de la
# SECRET_KEY de la tienda. Si comparten firma, un token de cliente de la tienda
# (que no tiene MFA) sirve como sesión de administrador.
ADMIN_SECRET_KEY=
SECRET_KEY=
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=30
# DEV_MODE por omisión es false (producción). Poner true SOLO en local.
# En producción: COOKIE_SECURE=true (requiere HTTPS) y DEV_MODE=false
DEV_MODE=true
COOKIE_SECURE=false

# --- Admin inicial (se crea al arrancar si no existe ningún admin) ---
ADMIN_EMAIL=yamilpintos18@gmail.com
ADMIN_PASSWORD=

# --- Tienda Nube (SOLO para migrar / refrescar el catálogo) ---
# Admin de la tienda → Configuración → Aplicaciones → Crear app privada
TIENDANUBE_STORE_ID=
TIENDANUBE_ACCESS_TOKEN=
TIENDANUBE_USER_AGENT=MiamiImport StockManager (tu-email@dominio.com)

# --- Precios ---
USD_TO_ARS_RATE=1410

# --- Stripe (claves SIEMPRE solo en backend) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
CHECKOUT_CURRENCY=ars

# --- Google OAuth (login con Google en la tienda) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- URLs públicas (CORS, callbacks, links de Stripe) ---
STORE_BASE_URL=http://localhost:8001
PANEL_BASE_URL=http://localhost:8000
# Lista separada por comas; si vacío usa STORE_BASE_URL + PANEL_BASE_URL
CORS_ORIGINS=

# --- Supabase Storage (imágenes de productos) ---
# Si están cargadas, las fotos van al bucket de Supabase (CDN) en vez del disco local.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SECRET_KEY=
SUPABASE_BUCKET=productos

# --- Backup de fotos a Drive (opcional) ---
LOCAL_BACKUP_PATH=

# --- Redeploy del bot desde el panel (opcional) ---
RENDER_DEPLOY_HOOK=
