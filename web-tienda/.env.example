# ==========================================================================
# WEB-TIENDA — variables de entorno (copiar como ".env" y completar).
# El .env está en .gitignore — NUNCA subir credenciales reales al repo.
# ==========================================================================

# --- Base de datos (DEBE apuntar a la MISMA base que panel-control) ---
# Local (dev): vacío => SQLite compartido en la raíz del proyecto.
# Producción (Render): la "Internal Database URL" del MISMO Postgres del panel.
DATABASE_URL=

# --- Seguridad ---
# OBLIGATORIA y de >=32 caracteres: sin ella el proceso NO arranca en producción.
# Generar con:  python -c "import secrets;print(secrets.token_urlsafe(48))"
# DEBE ser DISTINTA de la del panel (si comparten firma, un token de cliente de
# la tienda sirve como token de administrador).
SECRET_KEY=
SESSION_MINUTES=720          # 12 h de sesión de cliente
RESET_TOKEN_MINUTES=30       # ventana del link de recuperación de contraseña
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=30
# DEV_MODE por omisión es false (producción). Poner true SOLO en local.
DEV_MODE=true
COOKIE_SECURE=false

# --- Precios ---
USD_TO_ARS_RATE=1410

# --- Stripe (claves SIEMPRE solo en backend) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
CHECKOUT_CURRENCY=ars

# --- Google OAuth (login con Google) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- URLs públicas ---
STORE_BASE_URL=http://localhost:8001
PANEL_BASE_URL=http://localhost:8000
CORS_ORIGINS=

# --- Supabase Storage (imágenes de productos) ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SECRET_KEY=
SUPABASE_BUCKET=productos
